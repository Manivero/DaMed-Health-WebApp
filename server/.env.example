PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://localhost:27017/health-app

# JWT — access token (short-lived)
JWT_SECRET=change_me_to_a_long_random_string_min_32_chars
JWT_EXPIRES_IN=15m

# JWT — refresh token (long-lived)
JWT_REFRESH_SECRET=another_long_random_string_for_refresh_tokens
JWT_REFRESH_EXPIRES_IN=7d

# Stripe
STRIPE_SECRET=sk_test_your_stripe_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# App
CLIENT_URL=http://localhost:5173

# Email (Gmail App Password)
MAIL_USER=your@gmail.com
MAIL_PASS=your_app_password_here
